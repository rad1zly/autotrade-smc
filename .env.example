# Salin ke .env (JANGAN commit .env yang asli — isinya kunci rahasia).

# "minimax" atau "anthropic"
LLM_PROVIDER=minimax

# --- Minimax ---
# Verifikasi base_url & nama model terkini di console Minimax kamu; ini bisa
# berubah sewaktu-waktu di sisi provider.
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2

# --- Anthropic (opsional, kalau LLM_PROVIDER=anthropic) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- Gate validasi (dipakai brain/decision.py, dobel-check juga ada di EA) ---
PAF_MIN_CONFIDENCE=70
PAF_MIN_RR=2.0
PAF_MAX_SL_ATR=5.0
PAF_LLM_TIMEOUT_S=30
PAF_LLM_MAX_TOKENS=400
